# ── TinaCMS Cloud credentials ────────────────────────────────────────────────
# Leave both empty for local development: `npm run dev` edits the files on
# your machine directly, no account needed.
#
# For the live site, create a project at https://app.tina.io, connect this
# GitHub repo, then copy the values from the project's "Overview" page.

# Client ID (safe to expose; it is embedded in the /admin JavaScript)
TINA_PUBLIC_CLIENT_ID=

# Read-only content token (keep secret; used at build time only)
TINA_TOKEN=

# Branch TinaCloud should read and write. Keep this in sync with the branch
# connected in the TinaCloud project.
TINA_PUBLIC_BRANCH=main

# Optional local override. Vercel and Netlify are detected automatically.
# DEPLOY_TARGET=vercel
# DEPLOY_TARGET=netlify
