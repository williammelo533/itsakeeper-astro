---
/*
 * Reproduces the static site's <picture> pattern exactly: a WebP <source>
 * when a same-name .webp twin exists in /public/uploads, and an <img> with
 * true intrinsic dimensions measured at build time.
 */
import { imageMeta } from "../lib/images";

interface Props {
  src: string;
  alt?: string;
  pictureClass?: string;
  imgClass?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  fetchpriority?: "high" | "low" | "auto";
  dataTinaField?: string;
  responsive?: boolean;
  optimizedMobileWidth?: number;
  optimizedDesktopWidth?: number;
}

const {
  src,
  alt = "",
  pictureClass,
  imgClass,
  loading,
  decoding,
  fetchpriority,
  dataTinaField,
  responsive = false,
  optimizedMobileWidth,
  optimizedDesktopWidth,
} = Astro.props;
const meta = imageMeta(src);
const variantFor = (requested?: number) => {
  if (!requested || !meta.responsiveWebp?.length) return undefined;
  return (
    meta.responsiveWebp.find((variant) => variant.width === requested)?.path ||
    [...meta.responsiveWebp]
      .filter((variant) => variant.width <= requested)
      .sort((a, b) => b.width - a.width)[0]?.path ||
    meta.responsiveWebp[0]?.path
  );
};
const mobileOptimized = variantFor(optimizedMobileWidth);
const desktopOptimized = variantFor(optimizedDesktopWidth);
const sharedOptimized =
  mobileOptimized && mobileOptimized === desktopOptimized
    ? mobileOptimized
    : undefined;
---

<picture class={pictureClass} data-tina-field={dataTinaField || undefined}>
  {responsive && meta.desktopAvif && (
    <source
      media="(min-width: 768px)"
      srcset={meta.desktopAvif}
      type="image/avif"
    />
  )}
  {responsive && meta.mobileWebp && (
    <source
      media="(max-width: 767px)"
      srcset={meta.mobileWebp}
      type="image/webp"
    />
  )}
  {responsive && meta.desktopWebp && (
    <source
      media="(min-width: 768px)"
      srcset={meta.desktopWebp}
      type="image/webp"
    />
  )}
  {!sharedOptimized && mobileOptimized && (
    <source
      media="(max-width: 767px)"
      srcset={mobileOptimized}
      type="image/webp"
    />
  )}
  {!sharedOptimized && desktopOptimized && (
    <source
      media="(min-width: 768px)"
      srcset={desktopOptimized}
      type="image/webp"
    />
  )}
  {sharedOptimized && <source srcset={sharedOptimized} type="image/webp" />}
  {meta.webp && <source srcset={meta.webp} type="image/webp" />}
  <img
    class={imgClass}
    src={src}
    width={meta.width}
    height={meta.height}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
  />
</picture>
