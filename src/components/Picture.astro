---
/*
 * Emits a WebP source when optimized uploads exist, with an opt-in responsive
 * srcset, and always measures true intrinsic dimensions at build time.
 */
import { imageMeta } from "../lib/images";

interface Props {
  src: string;
  alt?: string;
  pictureClass?: string;
  imgClass?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  fetchpriority?: "high" | "low" | "auto";
  sizes?: string;
  dataTinaField?: string;
  responsive?: boolean;
  responsiveSrcset?: boolean;
  optimizedMobileWidth?: number;
  optimizedDesktopWidth?: number;
}

const {
  src,
  alt = "",
  pictureClass,
  imgClass,
  loading,
  decoding,
  fetchpriority,
  sizes,
  dataTinaField,
  responsive = false,
  responsiveSrcset = false,
  optimizedMobileWidth,
  optimizedDesktopWidth,
} = Astro.props;
const meta = imageMeta(src);
const generatedSrcset = responsiveSrcset
  ? meta.responsiveWebp
      ?.map((variant) => `${variant.path} ${variant.width}w`)
      .join(", ")
  : undefined;
const variantFor = (requested?: number) => {
  if (!requested || !meta.responsiveWebp?.length) return undefined;
  return (
    meta.responsiveWebp.find((variant) => variant.width === requested)?.path ||
    [...meta.responsiveWebp]
      .filter((variant) => variant.width <= requested)
      .sort((a, b) => b.width - a.width)[0]?.path ||
    meta.responsiveWebp[0]?.path
  );
};
const mobileOptimized = variantFor(optimizedMobileWidth);
const desktopOptimized = variantFor(optimizedDesktopWidth);
const sharedOptimized =
  mobileOptimized && mobileOptimized === desktopOptimized
    ? mobileOptimized
    : undefined;
---

<picture class={pictureClass} data-tina-field={dataTinaField || undefined}>
  {generatedSrcset && (
    <source srcset={generatedSrcset} sizes={sizes} type="image/webp" />
  )}
  {!generatedSrcset && responsive && meta.desktopAvif && (
    <source
      media="(min-width: 768px)"
      srcset={meta.desktopAvif}
      type="image/avif"
    />
  )}
  {!generatedSrcset && responsive && meta.mobileAvif && (
    <source
      media="(max-width: 767px)"
      srcset={meta.mobileAvif}
      type="image/avif"
    />
  )}
  {!generatedSrcset && responsive && meta.mobileWebp && (
    <source
      media="(max-width: 767px)"
      srcset={meta.mobileWebp}
      type="image/webp"
    />
  )}
  {!generatedSrcset && responsive && meta.desktopWebp && (
    <source
      media="(min-width: 768px)"
      srcset={meta.desktopWebp}
      type="image/webp"
    />
  )}
  {!generatedSrcset && !sharedOptimized && mobileOptimized && (
    <source
      media="(max-width: 767px)"
      srcset={mobileOptimized}
      type="image/webp"
    />
  )}
  {!generatedSrcset && !sharedOptimized && desktopOptimized && (
    <source
      media="(min-width: 768px)"
      srcset={desktopOptimized}
      type="image/webp"
    />
  )}
  {!generatedSrcset && sharedOptimized && <source srcset={sharedOptimized} type="image/webp" />}
  {!generatedSrcset && meta.webp && <source srcset={meta.webp} type="image/webp" />}
  <img
    class={imgClass}
    src={src}
    width={meta.width}
    height={meta.height}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
  />
</picture>
