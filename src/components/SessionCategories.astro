---
import Picture from "./Picture.astro";
import { tinaField } from "@tinacms/astro/tina-field";
import { slugify } from "../lib/content";

const { sessions } = Astro.props;
---

<section
  class="portfolio"
  id="sessions"
  aria-labelledby="sessions-title"
  data-tina-field={tinaField(sessions)}
>
  <div class="portfolio__intro section-intro">
    <p class="section-eyebrow" data-tina-field={tinaField(sessions, "eyebrow")}>
      {sessions.eyebrow}
    </p>
    <h2
      class="section-heading"
      id="sessions-title"
      data-tina-field={tinaField(sessions, "heading")}
    >{sessions.heading}</h2>
  </div>

  <div class="portfolio__grid">
    {sessions.cards.map((card, index) => (
      <a
        class="portfolio-card"
        id={slugify(card.label)}
        href={card.link || "#inquire"}
        data-session-prefill={card.prefill || undefined}
        aria-label={`Plan a ${card.label.toLowerCase()} photography session with Lisa`}
      >
        <span class="portfolio-card__image">
          <Picture
            imgClass="photo--editorial"
            src={card.image}
            alt={card.imageAlt}
            loading="lazy"
            decoding="async"
            optimizedMobileWidth={640}
            optimizedDesktopWidth={640}
            dataTinaField={tinaField(sessions, "cards", index)}
          />
        </span>
        <span class="portfolio-card__label-wrap">
          <span
            class="portfolio-card__label"
            data-tina-field={tinaField(card, "label")}
          >{card.label}</span>
        </span>
      </a>
    ))}
  </div>
</section>
