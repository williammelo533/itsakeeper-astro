---
import { tinaField } from "@tinacms/astro/tina-field";

const { faq } = Astro.props;
---

<section class="home-faq" id="faq" aria-labelledby="home-faq-title" data-tina-field={tinaField(faq)}>
  <div class="content-shell">
    <div class="section-intro section-intro--left">
      <p class="section-eyebrow">{faq.eyebrow}</p>
      <h2 class="section-heading" id="home-faq-title">{faq.heading}</h2>
    </div>
    <div class="home-faq__list">
      {faq.items.map((item, index) => (
        <details class="home-faq__item" open={index === 0 || undefined}>
          <summary>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.question}</h3>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
