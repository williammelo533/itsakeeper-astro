---
import Picture from "./Picture.astro";
import { tinaField } from "@tinacms/astro/tina-field";

const { meetLisa } = Astro.props;

const headingLine2 = (meetLisa.headingLine2 || "").trim();
const accentBreak = headingLine2.lastIndexOf(" ");
const headingLine2Stem = accentBreak > -1
  ? headingLine2.slice(0, accentBreak)
  : "";
const headingAccent = accentBreak > -1
  ? headingLine2.slice(accentBreak + 1)
  : headingLine2;
---

<section
  class="biography"
  id="meet-lisa"
  aria-labelledby="biography-title"
  data-tina-field={tinaField(meetLisa)}
>
  <div class="biography__shell design-shell">
    <div class="biography__copy">
      <p class="section-eyebrow" data-tina-field={tinaField(meetLisa, "eyebrow")}>
        {meetLisa.eyebrow}
      </p>
      <h2 class="section-heading" id="biography-title">
        <span
          class="biography__heading-line"
          data-tina-field={tinaField(meetLisa, "headingLine1")}
        >
          {meetLisa.headingLine1}
        </span>
        {headingLine2 && (
          <span
            class="biography__heading-line biography__heading-line--accent"
            data-tina-field={tinaField(meetLisa, "headingLine2")}
          >
            {headingLine2Stem && `${headingLine2Stem} `}
            <em class="biography__script-word">{headingAccent}</em>
          </span>
        )}
      </h2>
      <p class="editorial-copy" data-tina-field={tinaField(meetLisa, "story")}>
        {meetLisa.story}
      </p>
      {meetLisa.credit && (
        <p
          class="editorial-copy biography__credit"
          data-tina-field={tinaField(meetLisa, "credit")}
        >{meetLisa.credit}</p>
      )}
      <a class="outline-button outline-button--light biography__action" href="/about/">
        Meet Lisa
      </a>
    </div>

    <div class="biography__media">
      <div class="biography__line biography__line--vertical" aria-hidden="true"></div>
      <div class="biography__line biography__line--horizontal" aria-hidden="true"></div>
      <figure class="biography__portrait" data-biography-arch>
        <Picture
          imgClass="photo--editorial"
          src={meetLisa.portrait}
          alt={meetLisa.portraitAlt}
          loading="lazy"
          decoding="async"
          optimizedMobileWidth={640}
          optimizedDesktopWidth={640}
          dataTinaField={tinaField(meetLisa, "portrait")}
        />
      </figure>
      <div class="biography__print" aria-hidden="true" data-biography-print>
        <span class="biography__tape"></span>
        <Picture
          pictureClass="biography__print-picture"
          imgClass="photo--editorial biography__print-image"
          src={meetLisa.portrait}
          alt=""
          loading="lazy"
          decoding="async"
          optimizedMobileWidth={400}
        />
      </div>
    </div>
  </div>
</section>
