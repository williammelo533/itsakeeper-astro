---
import Picture from "./Picture.astro";
import { tinaField } from "@tinacms/astro/tina-field";

const { hero } = Astro.props;
---

<section
  class="hero"
  id="home"
  aria-labelledby="hero-title"
  data-tina-field={tinaField(hero)}
>
  <Picture
    pictureClass="hero__picture"
    imgClass="hero__image photo--editorial"
    src={hero.image}
    alt={hero.imageAlt}
    loading="eager"
    fetchpriority="high"
    decoding="sync"
    dataTinaField={tinaField(hero, "image")}
    responsive
  />
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="hero__title">
    <h1 class="hero__serif" id="hero-title" data-tina-field={tinaField(hero, "heading")}>
      {hero.heading}
    </h1>
    <p
      class="hero__script"
      aria-hidden="true"
      data-tina-field={tinaField(hero, "scriptLine")}
    >{hero.scriptLine}</p>
    {hero.subhead && <p class="hero__subhead">{hero.subhead}</p>}
    <div class="hero__actions">
      {hero.primaryCtaLabel && <a class="outline-button outline-button--light" href={hero.primaryCtaHref}>{hero.primaryCtaLabel}</a>}
      {hero.secondaryCtaLabel && <a class="hero__secondary" href={hero.secondaryCtaHref}>{hero.secondaryCtaLabel}</a>}
    </div>
  </div>
  {hero.trustBar && <p class="hero__trust">{hero.trustBar}</p>}
</section>
