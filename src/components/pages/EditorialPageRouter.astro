---
import type { EditorialPageData } from "../../content/page-types";
import AboutPage from "./AboutPage.astro";
import ContentPage from "./ContentPage.astro";
import FamilyPage from "./FamilyPage.astro";
import SeniorPage from "./SeniorPage.astro";

interface Props {
  page: EditorialPageData;
  settings: any;
  inquiry?: any;
}

const props = Astro.props;
const isAboutPage = props.page.route === "/about/";
const isFamilyPage = props.page.route === "/family-photographer-tri-cities-wa/";
const isSeniorPage = props.page.route === "/senior-photographer-tri-cities-wa/";
---

{isAboutPage
  ? <AboutPage {...props} />
  : isFamilyPage
    ? <FamilyPage {...props} />
  : isSeniorPage
    ? <SeniorPage {...props} />
    : <ContentPage {...props} />}
