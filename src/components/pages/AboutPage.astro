---
import type { EditorialPageData, PageSection } from "../../content/page-types";
import Picture from "../Picture.astro";
import "../../styles/about-page.css";

interface Props {
  page: EditorialPageData;
  settings: any;
  inquiry?: any;
}

const { page } = Astro.props;

const requireSection = (id: string): PageSection => {
  const section = page.sections.find((candidate) => candidate.id === id);
  if (!section) throw new Error(`About page is missing the required section: ${id}`);
  return section;
};

const origin = requireSection("it-started-with-my-own-children");
const nameStory = requireSection("why-its-a-keeper");
const cameraStory = requireSection("a-camera-a-scam-and-a-door-that-opened-anyway");
const lessons = requireSection("what-twenty-years-behind-the-camera-has-taught-me");
const belief = requireSection("what-i-believe-you-deserve");
const offCamera = requireSection("lisa-off-camera");
const credentials = requireSection("experience-and-credentials");

const lessonPrints = (lessons.items || []).filter((item) => item.image).slice(0, 3);
const beliefQuote = belief.items?.find((item) => item.quote)?.quote;
const originNote = origin.paragraphs?.[0];
const originParagraphs = origin.paragraphs?.slice(originNote ? 1 : 0);
const lessonLead = lessons.paragraphs?.[0];
const lessonParagraphs = lessons.paragraphs?.slice(lessonLead ? 1 : 0);
const heroHeadingParts = page.hero.heading.split(" — ");

const heroLeftImage = origin.secondaryImage || lessonPrints[0]?.image || belief.image;
const heroRightImage = lessonPrints[2]?.image || belief.image;
const originImage = origin.image || offCamera.secondaryImage || page.hero.image;
const originOverlapImage = origin.secondaryImage || lessonPrints[0]?.image;
const finalImage = page.finalCta?.image || belief.image;
const finalImageAlt = page.finalCta?.imageAlt || belief.imageAlt || "";
---

<article
  class="about-page"
  data-content-status={page.contentStatus}
  data-signature-device={page.signature}
>
  <header
    class:list={["about-hero", `tone-${page.hero.tone}`]}
    aria-labelledby="about-hero-title"
    data-about-hero
  >
    <div class="about-hero__stage">
      {page.hero.image && (
        <figure class="about-hero__portrait-field">
          <Picture
            src={page.hero.image}
            alt={page.hero.imageAlt || ""}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            responsiveSrcset
            sizes="(max-width: 767px) 100vw, (max-width: 1050px) 50vw, 43vw"
            imgClass="about-hero__portrait-image photo--editorial"
          />
        </figure>
      )}

      {heroLeftImage && (
        <figure
          class="about-hero__print about-hero__print--left"
          aria-hidden="true"
          data-about-hero-print="left"
        >
          <Picture
            src={heroLeftImage}
            alt=""
            loading="eager"
            decoding="async"
            optimizedMobileWidth={400}
            optimizedDesktopWidth={640}
            imgClass="photo--editorial"
          />
        </figure>
      )}

      {heroRightImage && (
        <figure
          class="about-hero__print about-hero__print--right"
          aria-hidden="true"
          data-about-hero-print="right"
        >
          <Picture
            src={heroRightImage}
            alt=""
            loading="eager"
            decoding="async"
            optimizedMobileWidth={400}
            optimizedDesktopWidth={640}
            imgClass="photo--editorial"
          />
        </figure>
      )}

      <div class="about-hero__wash" aria-hidden="true"></div>

      <div class="about-hero__copy">
        {page.hero.scriptLine && (
          <p class="about-script about-hero__script" aria-hidden="true">
            {page.hero.scriptLine}
          </p>
        )}
        <h1 id="about-hero-title">
          <span>{heroHeadingParts[0]}</span>
          {heroHeadingParts.length > 1 && (
            <span> — {heroHeadingParts.slice(1).join(" — ")}</span>
          )}
        </h1>
        {page.hero.intro && <p class="about-hero__intro">{page.hero.intro}</p>}
        {page.hero.links?.length && (
          <div class="about-hero__actions">
            {page.hero.links.map((link) => (
              <a class="outline-button" href={link.href}>{link.label}</a>
            ))}
          </div>
        )}
      </div>

    </div>
    <div class="about-hero__paper-edge" aria-hidden="true"></div>
  </header>

  <section
    id={origin.id}
    class:list={["about-origin", `tone-${origin.tone}`]}
    aria-labelledby={`${origin.id}-title`}
  >
    <div class="about-shell about-origin__inner">
      <div class="about-origin__media">
        {originImage && (
          <figure
            class="about-origin__arch"
            data-about-arch="origin"
            data-line-target="origin-arch"
          >
            <Picture
              src={originImage}
              alt={origin.imageAlt || offCamera.secondaryImageAlt || page.hero.imageAlt || ""}
              loading="eager"
              decoding="async"
              responsiveSrcset
              sizes="(max-width: 767px) 86vw, (max-width: 1050px) 44vw, 31rem"
              imgClass="photo--editorial"
            />
          </figure>
        )}

        {originOverlapImage && (
          <figure class="about-print about-origin__overlap">
            <Picture
              src={originOverlapImage}
              alt={origin.secondaryImageAlt || lessonPrints[0]?.imageAlt || ""}
              loading="lazy"
              decoding="async"
              optimizedMobileWidth={400}
              optimizedDesktopWidth={640}
              imgClass="photo--editorial"
            />
          </figure>
        )}

        {originNote && (
          <aside class="about-paper-note about-origin__note" aria-label="Lisa's beginning">
            <p>{originNote}</p>
          </aside>
        )}
      </div>

      <div class="about-origin__copy">
        <h2 id={`${origin.id}-title`}>{origin.heading}</h2>
        <div class="about-prose">
          {originParagraphs?.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </div>
    <span
      class="about-origin__crossline"
      aria-hidden="true"
      data-construction-line
      data-line-anchor="origin-arch"
      data-anchor-target="origin-arch"
    ></span>
  </section>

  <section
    id={nameStory.id}
    class:list={["about-name", `tone-${nameStory.tone}`]}
    aria-labelledby={`${nameStory.id}-title`}
  >
    <div class="about-shell about-name__inner">
      <div class="about-name__heading">
        <h2 id={`${nameStory.id}-title`}>{nameStory.heading}</h2>
      </div>
      <div class="about-name__copy">
        {nameStory.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section
    id={cameraStory.id}
    class:list={["about-camera", `tone-${cameraStory.tone}`]}
    aria-labelledby={`${cameraStory.id}-title`}
  >
    <div class="about-shell about-camera__inner">
      {cameraStory.image && (
        <figure class="about-print about-camera__print" data-line-target="camera-print">
          <span class="about-tape" aria-hidden="true"></span>
          <Picture
            src={cameraStory.image}
            alt={cameraStory.imageAlt || ""}
            loading="lazy"
            decoding="async"
            responsiveSrcset
            sizes="(max-width: 767px) 88vw, (max-width: 1050px) 43vw, 34rem"
            imgClass="photo--editorial"
          />
        </figure>
      )}

      <div class="about-camera__copy">
        <h2 id={`${cameraStory.id}-title`}>{cameraStory.heading}</h2>
        <div class="about-prose about-camera__paragraphs">
          {cameraStory.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section
    id={lessons.id}
    class:list={["about-lessons", `tone-${lessons.tone}`]}
    aria-labelledby={`${lessons.id}-title`}
  >
    <div class="about-shell about-lessons__inner">
      <header class="about-lessons__heading">
        <h2 id={`${lessons.id}-title`}>{lessons.heading}</h2>
        {lessonLead && <p>{lessonLead}</p>}
      </header>

      {lessonPrints.length > 0 && (
        <div
          class="about-lessons__gallery"
          role="group"
          aria-label="A selection of Lisa's portrait work"
        >
          {lessonPrints.map((item, index) => (
            <figure
              class:list={[
                "about-lessons__photo",
                { "about-lessons__photo--arch": index === 1 },
              ]}
              data-about-arch={index === 1 ? "lessons" : undefined}
            >
              <Picture
                src={item.image!}
                alt={item.imageAlt || ""}
                loading="lazy"
                decoding="async"
                responsiveSrcset
                sizes="(max-width: 767px) 84vw, (max-width: 1050px) 38vw, 33vw"
                imgClass="photo--editorial"
              />
            </figure>
          ))}
        </div>
      )}

      {lessonParagraphs?.length && (
        <div class="about-lessons__ledger">
          {lessonParagraphs.map((paragraph) => (
            <div class="about-lessons__entry">
              <p>{paragraph}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <section
    id={belief.id}
    class:list={["about-belief", `tone-${belief.tone}`]}
    aria-labelledby={`${belief.id}-title`}
  >
    <div class="about-belief__image">
      {belief.image && (
        <Picture
          src={belief.image}
          alt={belief.imageAlt || ""}
          loading="lazy"
          decoding="async"
          responsiveSrcset
          sizes="100vw"
          imgClass="about-belief__background-image photo--editorial"
        />
      )}
      <div class="about-belief__wash" aria-hidden="true"></div>
      <div class="about-shell about-belief__heading">
        <h2 id={`${belief.id}-title`}>{belief.heading}</h2>
        {beliefQuote && <blockquote><p>{beliefQuote}</p></blockquote>}
      </div>
    </div>

    <div class="about-shell about-belief__lower">
      <div class="about-paper-note about-belief__note">
        <span class="about-pin" aria-hidden="true"></span>
        <div class="about-belief__prose">
          {belief.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section
    id={offCamera.id}
    class:list={["about-personal", `tone-${offCamera.tone}`]}
    aria-labelledby={`${offCamera.id}-title`}
  >
    <div class="about-shell about-personal__inner">
      <div class="about-personal__copy">
        <h2 id={`${offCamera.id}-title`}>{offCamera.heading}</h2>
        <div class="about-prose">
          {offCamera.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>

      {(offCamera.image || offCamera.secondaryImage) && (
        <div class="about-personal__portraits" data-about-overlap="personal">
          {offCamera.image && (
            <figure
              class="about-personal__portrait about-personal__portrait--rear"
              data-about-layer="rear"
            >
              <Picture
                src={offCamera.image}
                alt={offCamera.imageAlt || ""}
                loading="lazy"
                decoding="async"
                responsiveSrcset
                sizes="(max-width: 767px) 74vw, (max-width: 1050px) 42vw, 32rem"
                imgClass="photo--editorial"
              />
            </figure>
          )}
          {offCamera.secondaryImage && (
            <figure
              class="about-print about-personal__portrait about-personal__portrait--front"
              data-about-layer="front"
            >
              <span class="about-tape" aria-hidden="true"></span>
              <Picture
                src={offCamera.secondaryImage}
                alt={offCamera.secondaryImageAlt || ""}
                loading="lazy"
                decoding="async"
                optimizedMobileWidth={400}
                optimizedDesktopWidth={640}
                imgClass="photo--editorial"
              />
            </figure>
          )}
        </div>
      )}
    </div>
  </section>

  <section
    id={credentials.id}
    class:list={["about-proof", `tone-${credentials.tone}`]}
    aria-labelledby={`${credentials.id}-title`}
  >
    <div class="about-shell about-proof__inner">
      <div class="about-proof__heading">
        <h2 id={`${credentials.id}-title`}>{credentials.heading}</h2>
      </div>
      {credentials.items?.length && (
        <ul class="about-proof__ledger">
          {credentials.items.map((item, index) => (
            <li>
              <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
              <p>{item.detail}</p>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  {page.finalCta && (
    <section
      class:list={["about-final", `tone-${page.finalCta.tone}`]}
      aria-labelledby="about-final-title"
    >
      {finalImage && (
        <Picture
          src={finalImage}
          alt={finalImageAlt}
          loading="lazy"
          decoding="async"
          responsiveSrcset
          sizes="100vw"
          imgClass="about-final__background photo--editorial"
        />
      )}
      <div class="about-final__wash" aria-hidden="true"></div>
      <div class="about-shell about-final__inner">
        <div class="about-final__frame">
          <h2 id="about-final-title">{page.finalCta.heading}</h2>
          <div class="about-final__invitation">
            {page.finalCta.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
            {page.finalCta.link && (
              <a class="outline-button" href={page.finalCta.link.href}>
                {page.finalCta.link.label}
              </a>
            )}
          </div>
        </div>
      </div>
    </section>
  )}
</article>
