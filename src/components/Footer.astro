---
import Picture from "./Picture.astro";
import { tinaField } from "@tinacms/astro/tina-field";
import { telHref } from "../lib/content";
import { footerNavigation } from "../lib/navigation";

const { settings } = Astro.props;
const phoneHref = telHref(settings.phone);
const serviceAreaLine = "Richland, Washington · Serving Richland, Kennewick and Pasco";
---

<footer class="site-footer" id="contact">
  <div class="footer-inner">
    <div class="footer-brand">
      <a class="brand-logo brand-logo--footer" href="/" aria-label={`${settings.businessName}, home`}>
        <Picture
          src={settings.logo}
          alt={settings.logoAlt}
          loading="lazy"
          optimizedMobileWidth={400}
          optimizedDesktopWidth={400}
          dataTinaField={tinaField(settings, "logo")}
        />
      </a>
      {settings.footerTagline && (
        <p data-tina-field={tinaField(settings, "footerTagline")}>
          {settings.footerTagline}
        </p>
      )}
    </div>

    <address class="footer-address">
      <strong>{settings.businessName}</strong><br />
      {serviceAreaLine}<br />
      <a href={`tel:${phoneHref}`}>{settings.phone}</a><br />
      <a href={`mailto:${settings.email}`}>{settings.email}</a>
    </address>

    <div class="footer-directory">
      <nav aria-label="Photography services">
        <p>Sessions</p>
        {footerNavigation.services.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>
      <nav aria-label="Explore the site">
        <p>Explore</p>
        {footerNavigation.explore.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>
      <nav aria-label="Planning guides">
        <p>Guides</p>
        {footerNavigation.guides.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>
      <nav aria-label="Service areas">
        <p>Places</p>
        {footerNavigation.places.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>
    </div>

    <div class="footer-links">
      <nav aria-label="Social media">
        {settings.social.instagram && (
          <a
            href={settings.social.instagram}
            target="_blank"
            rel="me noopener noreferrer"
          >Instagram</a>
        )}
        {settings.social.facebook && (
          <a
            href={settings.social.facebook}
            target="_blank"
            rel="me noopener noreferrer"
          >Facebook</a>
        )}
      </nav>
    </div>

    <p class="footer-copyright">
      &copy; <span data-current-year>2026</span> {settings.businessName}. All rights reserved.
    </p>
  </div>
</footer>
