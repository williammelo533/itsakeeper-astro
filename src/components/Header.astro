---
import Picture from "./Picture.astro";
import { tinaField } from "@tinacms/astro/tina-field";
import { isCurrentRoute, primaryNavigation } from "../lib/navigation";

interface Props {
  settings: any;
  homepage?: any;
  currentPath?: string;
}

const { settings, currentPath = "/" } = Astro.props;
---

<header class="site-header" data-site-header>
  <div class="header-inner">
    <button
      class="menu-toggle"
      type="button"
      aria-label="Open navigation"
      aria-controls="primary-navigation"
      aria-expanded="false"
      data-menu-toggle
    >
      <span class="menu-toggle__line" aria-hidden="true"></span>
      <span class="menu-toggle__line" aria-hidden="true"></span>
      <span class="menu-toggle__line" aria-hidden="true"></span>
    </button>

    <a class="brand-logo" href="/" aria-label={`${settings.businessName}, home`}>
      <Picture
        src={settings.logo}
        alt={settings.logoAlt}
        optimizedMobileWidth={400}
        optimizedDesktopWidth={400}
        dataTinaField={tinaField(settings, "logo")}
      />
    </a>

    <nav
      class="primary-nav"
      id="primary-navigation"
      aria-label="Primary navigation"
      data-primary-nav
    >
      <ul class="primary-nav__list">
        {primaryNavigation.map((link) => (
          <li class="primary-nav__item">
            <a
              class:list={["primary-nav__link", { "primary-nav__link--button": "button" in link && link.button }]}
              href={link.href}
              aria-current={isCurrentRoute(currentPath, link.href) ? "page" : undefined}
            >{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
