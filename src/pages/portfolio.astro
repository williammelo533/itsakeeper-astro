---
import TinaIsland from "@tinacms/astro/TinaIsland.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import JournalPortfolio from "../components/JournalPortfolio.astro";
import Base from "../layouts/Base.astro";
import { getStaticPortfolioPage } from "../lib/static-content";
import { pageManifest } from "../lib/page-manifest";
import { portfolioWrapper } from "../lib/tina/wrappers";

const page = getStaticPortfolioPage();
const data = page.data;
const homepage = data.homepage;
const settings = data.settings;
const entry = pageManifest.find((candidate) => candidate.id === "portfolio");
if (!entry) throw new Error("Portfolio manifest entry is missing.");
const title = entry.title;
const description = entry.summary;
---

<Base
  title={title}
  description={description}
  settings={settings}
  canonicalPath={entry.path}
  searchVisibility={entry.searchVisibility}
  schemaType={entry.schemaType}
  loadEditorialMotion={false}
>
  <Header settings={settings} homepage={homepage} currentPath={entry.path} />
  <main id="main-content">
    <TinaIsland name="portfolio" wrapper={portfolioWrapper} primary>
      <JournalPortfolio data={data} />
    </TinaIsland>
  </main>
  <Footer settings={settings} />
</Base>
